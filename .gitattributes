# Fork-owned files: always keep THIS fork's version when syncing from upstream.
#
# How these paths stay on our side:
#   - The sync workflow excludes them from the upstream delta entirely, so an
#     upstream edit to any of them is never part of what gets applied and can
#     never conflict (see .github/workflows/sync-upstream.yml).
#   - The `ours` merge driver below resolves them to our side for any manual
#     `git merge upstream/...` a maintainer runs outside the workflow.
# This file is the single source of truth for that protected list.

branding.json                         merge=ours

# App / installer / tray icons and the in-app logo (the fork's visual identity).
build/icon.*                          merge=ours
build/installerIcon*                  merge=ours
resources/icon*                       merge=ours
resources/app_icon_source.svg         merge=ours
src/renderer/src/assets/app-logo.png  merge=ours
